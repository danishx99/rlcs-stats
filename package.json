{
  "name": "rlcs-stats-loader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "load": "bun run src/run.ts",
    "load:players": "bun run src/run.ts --dir ./data --dataset players",
    "series:preflight": "psql \"${DATABASE_URL:-postgres://stats:stats_pw@localhost:5432/statsdb}\" -v ON_ERROR_STOP=1 -P pager=off -f sql/series-id-preflight.sql",
    "series:backfill": "psql \"${DATABASE_URL:-postgres://stats:stats_pw@localhost:5432/statsdb}\" -v ON_ERROR_STOP=1 -f sql/migrate-series-id.sql",
    "db:up": "docker compose up -d postgres adminer",
    "db:reset": "docker compose down -v && docker compose up -d",
    "prod:up": "docker compose -f docker-compose.prod.yml --env-file env/.env.api --profile localdb up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml --env-file env/.env.api down",
    "prod:logs": "docker compose -f docker-compose.prod.yml --env-file env/.env.api logs -f --tail=200",
    "prod:ps": "docker compose -f docker-compose.prod.yml --env-file env/.env.api ps",
    "prod:load": "docker compose -f docker-compose.prod.yml --env-file env/.env.api run --rm api bun run src/run.ts --dir ./data",
    "dev:full": "bun run db:up && bun run dev",
    "dev:api": "nodemon --watch server --ext ts,sql --exec \"bun server/index.ts\"",
    "dev:web": "vite --config web/vite.config.ts",
    "dev": "concurrently -n api,web -c red,blue \"bun run dev:api\" \"bun run dev:web\"",
    "build:web": "vite build --config web/vite.config.ts",
    "preview:web": "vite preview --config web/vite.config.ts",
    "test": "bun test"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "vite": "^5.2.11",
    "typescript": "^5.4.5"
  }
}
